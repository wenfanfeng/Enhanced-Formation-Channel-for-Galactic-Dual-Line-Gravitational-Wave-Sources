           RowBox[{"Pack", " ", "Candidate", " ", "Data", " ", 
            RowBox[{"(", 
             RowBox[{"only", " ", "orbital", " ", "elements"}], ")"}]}]}], "===",
           "===", "===", "===", "===", "===", "===", "===", "=="}], "*)"}], 
        RowBox[{"candidateData", "=", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"XRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"eiRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"IotaRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"OmegaRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"PericenterRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}]}], "}"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
          RowBox[{"==", 
           RowBox[{"Evaluate", " ", "Each", " ", "Candidate", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Direct", " ", "ODE"}], "+", "SNR"}], ")"}]}]}], "===", 
          "===", "===", "===", "===", "===", "===", "===", "=="}], "*)"}], 
        RowBox[{"resultsParallel", "=", 
         RowBox[{"ParallelMap", "[", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{"data", ",", 
             RowBox[{"Module", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                "aiVal", ",", "eiVal", ",", "\[Iota]Val", ",", 
                 "\[CapitalOmega]Val", ",", "\[Omega]Val", ",", "sol", ",", 
                 "piorbInS", ",", "snrZlk"}], "}"}], ",", 
               RowBox[{"(*", 
                RowBox[{"Unpack", " ", 
                 RowBox[{"tuple", ":", 
                  RowBox[{"only", " ", "orbital", " ", "elements"}]}]}], 
                "*)"}], 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                  "aiVal", ",", "eiVal", ",", "\[Iota]Val", ",", 
                   "\[CapitalOmega]Val", ",", "\[Omega]Val"}], "}"}], "=", 
                 "data"}], ";", "\[IndentingNewLine]", 
                RowBox[{"(*", 
                 RowBox[{
                 "Directly", " ", "solve", " ", "ODE", " ", "and", " ", 
                  "calculate", " ", "SNR", " ", "for", " ", "all", " ", 
                  "candidates"}], "*)"}], 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"sol", ",", "piorbInS"}], "}"}], "=", 
                 RowBox[{"Quiet", "@", 
                  RowBox[{"SolveZlk", "[", 
                   RowBox[{
                   "aiVal", ",", "eiVal", ",", "\[Iota]Val", ",", 
                    "\[CapitalOmega]Val", ",", "\[Omega]Val"}], "]"}]}]}], 
                ";", "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"sol", "===", "$Failed"}], ",", "False", ",", 
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"!", 
                    RowBox[{"MatchQ", "[", 
                    RowBox[{"sol", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"eSecular", "->", "_InterpolatingFunction"}], ",", 
                    RowBox[{
                    "\[Iota]Secular", "->", "_InterpolatingFunction"}], ",", 
                    RowBox[{
                    "\[CapitalOmega]Secular", "->", 
                    "_InterpolatingFunction"}], ",", 
                    RowBox[{
                    "\[Omega]Secular", "->", "_InterpolatingFunction"}]}], 
                    "}"}]}], "]"}]}], ",", "False", ",", 
                    RowBox[{
                    RowBox[{"snrZlk", "=", 
                    RowBox[{"Quiet", "@", 
                    RowBox[{"Check", "[", 
                    RowBox[{
                    RowBox[{"CalculateSnrZlkFromSol", "[", 
                    RowBox[{"aiVal", ",", "sol", ",", "piorbInS"}], "]"}], 
                    ",", "Indeterminate"}], "]"}]}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"NumericQ", "[", "snrZlk", "]"}], "&&", 
                    RowBox[{"snrZlk", ">=", "5"}]}]}]}], "]"}]}], "]"}]}]}], 
              "]"}]}], "]"}], ",", "candidateData"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Sanitize", " ", "any", " ", "unevaluated", " ", "Return", " ", 
          "artifacts"}], "*)"}], 
        RowBox[{"resultsParallel", "=", 
         RowBox[{"resultsParallel", "/.", " ", 
          RowBox[{"{", 
           RowBox[{"Null", "->", "False"}], "}"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pointsInRegion1", "=", 
         RowBox[{"Total", "@", 
          RowBox[{"Boole", "[", "resultsParallel", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
