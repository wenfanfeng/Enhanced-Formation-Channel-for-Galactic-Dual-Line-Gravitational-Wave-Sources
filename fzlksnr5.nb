      RowBox[{"Thermal", " ", "y", " ", "Distribution"}], "===", "===", "===",
       "===", "===", "===", "===", "===", "=="}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n===== [Part 1: Thermal y Distribution Results] =====\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"timeThermal", ",", 
       RowBox[{"{", 
