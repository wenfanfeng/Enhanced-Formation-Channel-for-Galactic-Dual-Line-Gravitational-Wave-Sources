               RowBox[{"N", "[", 
                RowBox[{"0", "/", "pointsInRegion2"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", "}"}], ",", "region2Points"}], "}"}], "]"}]}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
