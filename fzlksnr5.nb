     "major", " ", "axis", " ", "and", " ", "angle", " ", "samples"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"XRandom", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"RandomReal", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}], ",", "NPoints"}], "]"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"AiMaxSample", "^", "5"}], "-", 
           RowBox[{"AiMin", "^", "5"}]}], ")"}]}], "+", 
