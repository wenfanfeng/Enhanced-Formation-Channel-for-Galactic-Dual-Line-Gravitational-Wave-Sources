             RowBox[{"resultsParallel", ",", "True"}], "]"}]}], ",", 
           RowBox[{"{", "}"}], ",", 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "passing", "}"}], ",", 
             RowBox[{
              RowBox[{"passing", "=", 
               RowBox[{"Pick", "[", 
                RowBox[{
                "candidateData", ",", "resultsParallel", ",", "True"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], ",", 
                  RowBox[{"1", "-", 
                   RowBox[{"#", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], "&"}], "/@", 
               "passing"}]}]}], "   ", 
            RowBox[{"(*", 
             RowBox[{"{", 
              RowBox[{"ai", ",", 
               RowBox[{"1", "-", "ei"}]}], "}"}], "*)"}], "]"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
