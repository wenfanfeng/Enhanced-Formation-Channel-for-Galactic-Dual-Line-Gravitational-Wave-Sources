           RowBox[{"Area", " ", "Ratio"}]}], "===", "===", "===", "===", "===",
           "===", "===", "===", "=="}], "*)"}], 
        RowBox[{"areaRatio", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"pointsInRegion2", "==", "0"}], ",", 
