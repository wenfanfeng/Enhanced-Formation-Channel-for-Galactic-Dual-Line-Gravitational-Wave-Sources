   "\n", 
   RowBox[{
    RowBox[{"PericenterRandom", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"2", " ", "Pi"}]}], "}"}], ",", "NPoints"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Generate", " ", "eccentricity", " ", "samples", " ", "for", " ", "both", 
     " ", "distributions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"YMin", "=", "0"}], ";", 
    RowBox[{"YMax", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Con", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "YMin"}], ")"}], "^", "2"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "YMax"}], ")"}], "^", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"U", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", "NPoints"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Term", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "YMin"}], ")"}], "^", "2"}], "-", 
      RowBox[{"U", "*", "Con"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"YRandomThermal", "=", 
     RowBox[{"1", "-", 
      RowBox[{"Sqrt", "[", "Term", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"EiRandomThermal", "=", 
     RowBox[{"1", "-", "YRandomThermal"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"YRandomUniform", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", "NPoints"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"EiRandomUniform", "=", 
     RowBox[{"1", "-", "YRandomUniform"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
