         "region2PointsThermal"}], "}"}]}], "}"}], "=", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"CalculateRegionCounts", "[", 
       RowBox[{
       "EiRandomThermal", ",", "XRandom", ",", "IotaRandom", ",", 
        "OmegaRandom", ",", "PericenterRandom"}], "]"}], "]"}]}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Convert", " ", "seconds", " ", "to", " ", "hours", " ", "and", " ", 
     "minutes"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
