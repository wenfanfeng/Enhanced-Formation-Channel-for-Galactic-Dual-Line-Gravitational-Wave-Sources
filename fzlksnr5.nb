           RowBox[{"N", "[", 
            RowBox[{"pointsInRegion1", "/", "pointsInRegion2"}], "]"}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Return", ":", 
          RowBox[{"counts", "+", 
           RowBox[{
           "scatter", " ", "point", " ", "lists", " ", "for", " ", 
            "plotting"}]}]}], "*)"}], 
        RowBox[{"{", 
         RowBox[{
         "pointsInRegion1", ",", "pointsInRegion2", ",", "areaRatio", ",", 
          "region1Points", ",", "region2Points"}], "}"}]}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
