      RowBox[{
      "10.", " ", "Generate", " ", "All", " ", "Sampling", " ", "Data"}]}], "===",
      "===", "===", "===", "===", "===", "===", "===", "=="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NPoints", "=", 
     RowBox[{"10", "^", "5"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "125", "]"}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Generate", " ", "common", " ", "semi"}], "-", 
