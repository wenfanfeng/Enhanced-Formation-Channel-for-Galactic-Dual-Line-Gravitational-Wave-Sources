                 RowBox[{"ei", "<=", "eThreshold"}]}], "]"}]}], "]"}]}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
            "XRandom", ",", "eiRandom", ",", "aRVec", ",", "eThresholdVec"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"candidateIndices", "=", 
         RowBox[{"Flatten", "@", 
          RowBox[{"Position", "[", 
           RowBox[{"candidateMask", ",", "True"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
          RowBox[{"==", 
           RowBox[{
           "Pack", " ", "Candidate", " ", "Data", " ", "into", " ", 
            "Tuples"}]}], "===", "===", "===", "===", "===", "===", "===", "===",
           "=="}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "candidateIndices", "]"}], "===", "0"}], 
          ",", 
          RowBox[{"(*", 
           RowBox[{"No", " ", 
            RowBox[{"candidates", ":", 
             RowBox[{"return", " ", "zeros", " ", "immediately"}]}]}], "*)"}], 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", "pointsInRegion2", ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"pointsInRegion2", "==", "0"}], ",", 
