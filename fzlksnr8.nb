       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", "NPoints"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Term", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "YMin"}], ")"}], "^", "2"}], "-", 
