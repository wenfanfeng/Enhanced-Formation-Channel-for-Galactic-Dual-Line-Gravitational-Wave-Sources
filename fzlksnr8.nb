                    RowBox[{"!", 
                    RowBox[{"MatchQ", "[", 
                    RowBox[{"sol", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"eSecular", "->", "_InterpolatingFunction"}], ",", 
                    RowBox[{
                    "\[Iota]Secular", "->", "_InterpolatingFunction"}], ",", 
                    RowBox[{
                    "\[CapitalOmega]Secular", "->", 
                    "_InterpolatingFunction"}], ",", 
                    RowBox[{
                    "\[Omega]Secular", "->", "_InterpolatingFunction"}]}], 
                    "}"}]}], "]"}]}], ",", "False", ",", 
                    RowBox[{
                    RowBox[{"snrZlk", "=", 
                    RowBox[{"Quiet", "@", 
                    RowBox[{"Check", "[", 
                    RowBox[{
                    RowBox[{"CalculateSnrZlkFromSol", "[", 
                    RowBox[{"aiVal", ",", "sol", ",", "piorbInS"}], "]"}], 
                    ",", "Indeterminate"}], "]"}]}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"NumericQ", "[", "snrZlk", "]"}], "&&", 
                    RowBox[{"snrZlk", ">=", "8"}]}]}]}], "]"}]}], "]"}]}]}], 
              "]"}]}], "]"}], ",", "candidateData"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
