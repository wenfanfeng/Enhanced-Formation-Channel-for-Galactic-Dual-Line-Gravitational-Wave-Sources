       RowBox[{"(", 
        RowBox[{"1", "-", "YMin"}], ")"}], "^", "2"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "YMax"}], ")"}], "^", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"U", "=", 
