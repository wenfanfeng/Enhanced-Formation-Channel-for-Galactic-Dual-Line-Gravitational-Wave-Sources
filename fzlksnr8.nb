            RowBox[{"eiRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"IotaRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"OmegaRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}], ",", 
            RowBox[{"PericenterRandom", "[", 
             RowBox[{"[", "candidateIndices", "]"}], "]"}]}], "}"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
          RowBox[{"==", 
           RowBox[{"Evaluate", " ", "Each", " ", "Candidate", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Direct", " ", "ODE"}], "+", "SNR"}], ")"}]}]}], "===", 
          "===", "===", "===", "===", "===", "===", "===", "=="}], "*)"}], 
        RowBox[{"resultsParallel", "=", 
         RowBox[{"ParallelMap", "[", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{"data", ",", 
             RowBox[{"Module", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                "aiVal", ",", "eiVal", ",", "\[Iota]Val", ",", 
                 "\[CapitalOmega]Val", ",", "\[Omega]Val", ",", "sol", ",", 
                 "piorbInS", ",", "snrZlk"}], "}"}], ",", 
               RowBox[{"(*", 
                RowBox[{"Unpack", " ", 
                 RowBox[{"tuple", ":", 
                  RowBox[{"only", " ", "orbital", " ", "elements"}]}]}], 
                "*)"}], 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                  "aiVal", ",", "eiVal", ",", "\[Iota]Val", ",", 
                   "\[CapitalOmega]Val", ",", "\[Omega]Val"}], "}"}], "=", 
                 "data"}], ";", "\[IndentingNewLine]", 
                RowBox[{"(*", 
                 RowBox[{
                 "Directly", " ", "solve", " ", "ODE", " ", "and", " ", 
                  "calculate", " ", "SNR", " ", "for", " ", "all", " ", 
                  "candidates"}], "*)"}], 
                RowBox[{
                 RowBox[{"{", 
