                 RowBox[{"ei", "<=", "eThreshold"}]}], "]"}]}], "]"}]}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
            "XRandom", ",", "eiRandom", ",", "aRVec", ",", "eThresholdVec"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"candidateIndices", "=", 
         RowBox[{"Flatten", "@", 
