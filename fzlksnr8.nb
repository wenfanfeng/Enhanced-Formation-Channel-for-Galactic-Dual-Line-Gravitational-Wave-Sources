           "=="}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "candidateIndices", "]"}], "===", "0"}], 
          ",", 
          RowBox[{"(*", 
           RowBox[{"No", " ", 
            RowBox[{"candidates", ":", 
             RowBox[{"return", " ", "zeros", " ", "immediately"}]}]}], "*)"}], 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", "pointsInRegion2", ",", 
