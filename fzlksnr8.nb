           "===", "===", "===", "===", "===", "===", "===", "=="}], "*)"}], 
        RowBox[{"candidateData", "=", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"XRandom", "[", 
