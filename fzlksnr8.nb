                    RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], "&"}], "/@", 
               "passing"}]}]}], "   ", 
            RowBox[{"(*", 
             RowBox[{"{", 
              RowBox[{"ai", ",", 
               RowBox[{"1", "-", "ei"}]}], "}"}], "*)"}], "]"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
